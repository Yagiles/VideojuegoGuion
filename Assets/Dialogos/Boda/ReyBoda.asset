  m_Name: ReyBoda
  m_EditorClassIdentifier: Assembly-CSharp::DialogoData
  lineas:
  - nombrePersonaje: "T\xFA"
    texto: "\xBFEs usted el Rey del que me han hablado?"
  - nombrePersonaje: Rey
    texto: Por fin llegas. Te estaba esperando.
  - nombrePersonaje: "T\xFA"
    texto: Pero si...
  - nombrePersonaje: Rey
    texto: Tengo un poco de prisa por llegar al castillo.
  - nombrePersonaje: Rey
    texto: 'Disfrute del resto de la boda. '
  - nombrePersonaje: Rey
    texto: Cuando termine, vaya a buscarme a la sala de tronos.
  avanceAutomatico: 0
  duracionLinea: 2
