  m_Script: {fileID: 11500000, guid: e28186e85056be5458f4bb9cfbfbff22, type: 3}
  m_Name: InvitadosBoda
  m_EditorClassIdentifier: Assembly-CSharp::DialogoData
  lineas:
  - nombrePersonaje: Franfishco
    texto: "Ay, \xA1hola! \xA1Cu\xE1nto tiempo!"
  - nombrePersonaje: Franfishco
    texto: Me alegro que hayas venido.
  - nombrePersonaje: Franfishco
    texto: "Llevabas tanto tiempo desaparecido que no sab\xEDa si lo har\xEDas."
  - nombrePersonaje: "T\xFA"
    texto: Disculpe, pero...
  - nombrePersonaje: "Ni\xF1a"
    texto: <i>Sniff<i>...
  - nombrePersonaje: "Ni\xF1a"
    texto: "Crecen tan r\xE1pido."
  - nombrePersonaje: "Ni\xF1a"
    texto: "Hacen tan buena pareja, \xBFno lo crees?."
  - nombrePersonaje: "T\xFA"
    texto: Emm...
  - nombrePersonaje: "T\xFA"
    texto: "S\xED, supongo..."
  - nombrePersonaje: "T\xFA"
    texto: "\xBFMe podr\xEDa explicar alguno qu\xE9 es este sitio?"
  - nombrePersonaje: Franfishco
    texto: (<i>Mira hacia los lados, confuso<i>)
  - nombrePersonaje: Franfishco
    texto: "\xBFEl bosque?"
  - nombrePersonaje: "T\xFA"
    texto: "S\xED. El bosque y...vosotros."
  - nombrePersonaje: "Ni\xF1a"
    texto: "\xBFEsos son minihamburguesas? Me muero de hambre."
  - nombrePersonaje: "Ni\xF1a"
    texto: "\xA1No he comido nada en dos minutos! \xBFTe lo puedes creer?"
  avanceAutomatico: 0
  duracionLinea: 2
